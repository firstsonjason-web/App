rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthed() { return request.auth != null; }
    function isOwner(userId) { return isAuthed() && request.auth.uid == userId; }

    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read: if isAuthed();
      allow create: if isOwner(userId);
      // Allow updates to most profile fields, but protect subscription fields
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'subscriptionPlan', 'subscriptionStatus', 'subscriptionUpdatedAt', 
        'trialEndsAt', 'trialStartedAt', 'subscriptionCancelledAt'
      ]);
      // Subscription fields can only be updated by admin functions (via service account)
      allow update: if false; // Direct client updates to subscription fields are blocked
      
      // Subcollections like userStats or achievements
      match /{allPaths=**} {
        allow read: if isAuthed();
        allow write: if isOwner(userId);
      }
    }
    
    // Payments collection - only readable by owner, writable by system only
    match /payments/{paymentId} {
      allow read: if isAuthed() && request.auth.uid == resource.data.userId;
      allow create, update, delete: if false;
    }
    
    // stripe_customers - system managed, not accessible from client
    match /stripe_customers/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Goals & Activities - Personal progress data
    match /goals/{goalId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthed() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /activities/{activityId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthed() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Communities & Posts - Social features
    match /communities/{communityId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isAuthed() && request.auth.uid == resource.data.createdBy;
    }

    match /posts/{postId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == request.resource.data.userId;
      // Owners full control; others can only touch likes/replies
      allow update: if isAuthed() && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'replies', 'likeIds'])
      );
      allow delete: if isOwner(resource.data.userId);
    }

    // Comments collection - users can manage their own comments
    match /comments/{commentId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if isOwner(resource.data.authorId);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      // Anyone can create a notification for another user
      allow create: if isAuthed();
    }

    // Friends collection - users can manage their own friend relationships
    match /friends/{friendId} {
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.friendId);
      allow create: if isAuthed() &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthed() &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.friendId);
    }

    // FriendRequests collection - users can manage their own friend requests
    match /friendRequests/{requestId} {
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.friendId ||
         resource.data.status == 'accepted');
      allow create: if isAuthed() &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthed() &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.friendId);
    }

    // Chats collection - users can access their own chats
    match /chats/{chatId} {
      allow read: if isAuthed() &&
        (chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid));
      allow create: if isAuthed() &&
        (chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid));
      allow write: if false; // managed via messages subcollection
    }

    // Chat messages subcollection - users can send/receive messages in their chats
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthed() &&
        (chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid));
      allow create: if isAuthed() &&
        request.auth.uid == request.resource.data.senderId &&
        (chatId.matches(request.auth.uid + '_.*') || chatId.matches('.*_' + request.auth.uid));
      allow update: if isOwner(resource.data.senderId);
      allow delete: if false;
    }

    // Rankings collection - public read for authenticated users
    match /rankings/{rankingId} {
      allow read: if isAuthed();
      allow write: if false;
    }
    match /global_rankings/{period} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // Screen Time Data - users can only access their own data
    match /screenTime/{docId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Hyper Focus Sessions - users can only access their own sessions
    match /hyperFocusSessions/{sessionId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // UGC Moderation (User Reporting)
    match /reports/{reportId} {
      allow create: if isAuthed() && request.auth.uid == request.resource.data.reporterId;
      allow read, update, delete: if false;
    }

    match /admin/{document=**} { allow read, write: if false; }
    match /public/{document=**} { allow read: if true; allow write: if false; }
  }
}
